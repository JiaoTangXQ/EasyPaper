# Copy to .env and fill in — used by docker-compose.prod.yml.
# (.env is gitignored; never commit real secrets.)

# Your public domain. A DNS A/AAAA record must point at this server, and
# ports 80 + 443 must be reachable for Caddy to obtain a TLS certificate.
DOMAIN=papers.example.com

# Postgres credentials. The db is internal-only, but still use a strong password.
POSTGRES_USER=easypaper
POSTGRES_PASSWORD=change-me-to-a-long-random-string
POSTGRES_DB=easypaper
